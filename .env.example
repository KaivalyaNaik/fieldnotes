# GitHub backend (required for the default deploy backend).
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Pluggable deploy backend. Defaults to "github".
FIELDNOTES_DEPLOY_BACKEND=github

# Map logical service names to GitHub Actions workflow stems.
# Set ONE of these (not both). Leave both unset to pass `service` through verbatim.
FIELDNOTES_SERVICE_MAP=payments=deploy-payments,api=release,web=deploy-web
# FIELDNOTES_SERVICE_MAP_FILE=/etc/fieldnotes/services.json

# Loki backend (required for the default log backend).
LOKI_URL=https://logs-prod-006.grafana.net
LOKI_USER_ID=
LOKI_API_KEY=

# Pluggable log backend. Defaults to "loki".
FIELDNOTES_LOG_BACKEND=loki

# Loki label name to filter on. Defaults to "service".
# FIELDNOTES_LOKI_LABEL=service

# Map logical service names to Loki label values.
# Set ONE of these (not both). Leave both unset to pass `service` through verbatim.
# FIELDNOTES_LOG_SERVICE_MAP=payments=payments-prod,api=api-prod,web=web-prod
# FIELDNOTES_LOG_SERVICE_MAP_FILE=/etc/fieldnotes/log-services.json

# Alertmanager backend (required for the default alerts backend).
ALERTMANAGER_URL=https://alertmanager.internal
# Optional Basic auth (both required together; leave both unset for in-cluster Alertmanager).
# ALERTMANAGER_USER_ID=
# ALERTMANAGER_API_KEY=

# Pluggable alerts backend. Defaults to "alertmanager".
FIELDNOTES_ALERT_BACKEND=alertmanager

# Alertmanager label name to filter on. Defaults to "service".
# FIELDNOTES_ALERTMANAGER_LABEL=service

# Map logical service names to Alertmanager label values.
# Set ONE of these (not both). Leave both unset to pass `service` through verbatim.
# FIELDNOTES_ALERT_SERVICE_MAP=payments=payments-prod,api=api-prod,web=web-prod
# FIELDNOTES_ALERT_SERVICE_MAP_FILE=/etc/fieldnotes/alert-services.json
