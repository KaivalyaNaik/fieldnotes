# GitHub backend (required for the default deploy backend).
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Pluggable deploy backend. Defaults to "github".
FIELDNOTES_DEPLOY_BACKEND=github

# Map logical service names to GitHub Actions workflow stems.
# Set ONE of these (not both). Leave both unset to pass `service` through verbatim.
FIELDNOTES_SERVICE_MAP=payments=deploy-payments,api=release,web=deploy-web
# FIELDNOTES_SERVICE_MAP_FILE=/etc/fieldnotes/services.json
